{% comment %}
Product Collection Tabs Section
Customizable product grid with category tabs
{% endcomment %}
<style>
/* Product Collection Tabs - Clean Minimal Design */
.pct-section {
padding: var(--pct-section-padding, 48px) 0;
color: var(--pct-text-color, #1a1a1a);
position: relative;
}
.pct-container {
max-width: 1460px;
margin: 0 auto;
padding: 0 20px;
}
/* ========== TABS NAVIGATION ========== */
.pct-tabs {
display: flex;
gap: 4px;
margin-bottom: 40px;
overflow-x: auto;
overflow-y: hidden;
-webkit-overflow-scrolling: touch;
scrollbar-width: none;
-ms-overflow-style: none;
justify-content: center;
}
.pct-tabs::-webkit-scrollbar {
display: none;
}
.pct-tab {
position: relative;
padding: 12px 18px;
background: #fff6ef;
border: none;
font-size: 15px;
font-weight: 500;
color: #666;
cursor: pointer;
transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
white-space: nowrap;
font-family: var(--font-h3--family);
border: 1px solid #ddd;
line-height: 1;
}
.pct-tab:hover {
color: rgb(217 35 123);
border-color: rgb(217 35 123);
}
.pct-tab--active {
color: rgb(217 35 123);
font-weight: 600;
border: 1px solid rgb(217 35 123);
}
/* ========== GRID LAYOUT ========== */
.pct-content {
position: relative;
min-height: 400px;
}
.pct-grid {
display: none;
grid-template-columns: repeat(2, 1fr);
gap: 16px;
animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
border-radius: 12px;
}
.pct-grid[hidden] {
display: none !important;
}
.pct-grid--active {
display: grid;
}
@keyframes fadeIn {
from {
opacity: 0;
transform: translateY(8px);
}
to {
opacity: 1;
transform: translateY(0);
}
}
/* Responsive grid columns */
@media (min-width: 640px) {
.pct-grid {
grid-template-columns: repeat(2, 1fr);
}
}
@media (min-width: 1024px) {
.pct-grid {
grid-template-columns: repeat(5, 1fr);
}
}
/* ========== PRODUCT CARD ========== */
.pct-card {
position: relative;
overflow: hidden;
transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.pct-card:hover {
border-color: rgba(0, 0, 0, 0.1);
}
/* ========== BADGE ========== */
.pct-badge {
position: absolute;
top: 6px;
left: 6px;
background: #e63946;
color: #fff;
padding: 3px 8px;
font-size: 10px;
z-index: 2;
line-height: 1;
text-transform: uppercase;
border-radius: 4px;
}
.pct-badge--new {
background: #4a90e2;
box-shadow: 0 2px 8px rgba(74, 144, 226, 0.3);
}
/* ========== PRODUCT IMAGE ========== */
.pct-card__image {
position: relative;
display: block;
aspect-ratio: 4 / 6;
overflow: hidden;
background: #f8f8f8;
border-radius: 12px;
}
.pct-card__image img {
width: 100%;
height: 100%;
object-fit: cover;
transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.pct-card:hover .pct-card__image img {
transform: scale(1.05);
}
.pct-placeholder {
width: 100%;
height: 100%;
opacity: 0.3;
}
/* ========== PRODUCT INFO ========== */
.pct-card__info {
padding: 16px 0;
}
.pct-card__title {
margin: 0 0 8px;
font-size: 14px;
font-weight: 500;
line-height: 1.4;
color: #111;
display: -webkit-box;
max-width: 200px;
-webkit-line-clamp: 2;
-webkit-box-orient: vertical;
overflow: hidden;
}
.pct-card__title a {
color: inherit;
text-decoration: none;
transition: color 0.2s ease;
}
.pct-card__title a:hover {
color: #222;
}
/* ========== RATING STARS ========== */
.pct-rating {
display: flex;
align-items: center;
gap: 6px;
margin-bottom: 8px;
}
.pct-stars {
position: relative;
display: inline-block;
font-size: 14px;
line-height: 1;
color: #ffd700;
}
.pct-stars__fill {
position: relative;
display: inline-block;
overflow: hidden;
width: calc(var(--rating, 0) * 20%);
}
.pct-stars__empty {
position: absolute;
top: 0;
left: 0;
color: #ddd;
}
.pct-rating__count {
font-size: 13px;
color: #999;
font-weight: 400;
}
/* ========== PRICE ========== */
.pct-price {
display: flex;
align-items: center;
gap: 8px;
margin-bottom: 12px;
flex-wrap: wrap;
line-height: 1;
}
.pct-price__regular,
.pct-price__sale {
font-size: 16px;
color: #111;
}
.pct-price__compare {
font-size: 14px;
color: #999;
text-decoration: line-through;
font-weight: 400;
}
/* ========== VARIANT SWATCHES ========== */
.pct-variants {
display: flex;
gap: 6px;
flex-wrap: wrap;
}
.pct-variant {
width: 28px;
height: 28px;
border-radius: 50%;
border: 2px solid #e0e0e0;
background-size: cover;
background-position: center;
cursor: pointer;
transition: all 0.2s ease;
padding: 0;
}
.pct-variant:hover {
border-color: #222;
transform: scale(1.1);
}
.pct-variant:focus {
outline: 2px solid #222;
outline-offset: 2px;
}
/* ========== SIZE BUTTONS ========== */
{% comment %} .size-custom {
display: flex;
flex-wrap: wrap;
gap: 6px;
margin-top: 10px;
}
.variant-size-btn {
min-width: 32px;
height: 32px;
padding: 0 10px;
border: 1px solid #d8d8d8;
background: transparent;
color: #111;
font-size: 12px;
line-height: 1;
cursor: pointer;
border-radius: 4px;
}
.variant-size-btn.not-ai {
opacity: 0.45;
text-decoration: line-through;
cursor: not-allowed;
} {% endcomment %}
/* ========== FOOTER / VIEW ALL ========== */
.pct-footer {
text-align: center;
margin-top:0 !important;
}
.pct-button {
display: inline-flex;
align-items: center;
gap: 8px;
padding: 12px 22px;
background: transparent;
border: 1px solid #222;
color: #222;
font-size: 15px;
text-decoration: none;
transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
line-height: 1;
}
.pct-button:hover {
background: #222;
color: #fff;
transform: translateY(-2px);
box-shadow: 0 8px 20px rgba(45, 95, 63, 0.2);
}
.pct-button svg {
transition: transform 0.3s ease;
}
.pct-button:hover svg {
transform: translateX(4px);
}
/* ========== EMPTY STATE ========== */
.pct-empty {
grid-column: 1 / -1;
padding: 60px 20px;
text-align: center;
color: #999;
font-size: 15px;
}
/* ========== ACCESSIBILITY ========== */
.pct-tab:focus-visible,
.pct-card__title a:focus-visible,
.pct-button:focus-visible {
outline: 2px solid #222;
outline-offset: 4px;
}
/* ========== LOADING STATE ========== */
.pct-card.is-loading {
pointer-events: none;
}
.pct-card.is-loading .pct-card__image::after {
content: '';
position: absolute;
inset: 0;
background: linear-gradient(
90deg,
transparent,
rgba(255, 255, 255, 0.4),
transparent
);
animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
0% {
transform: translateX(-100%);
}
100% {
transform: translateX(100%);
}
}
/* ========== DECORATIVE IMAGES ========== */
/* ========== RESPONSIVE DESIGN ========== */
@media (max-width: 768px) {
.pct-card__image {
border-radius: 8px;
}
}
@media (max-width: 640px) {
.pct-section {
padding: var(--pct-section-padding, 32px) 0;
}
.pct-container {
padding: 0 16px;
}
.pct-tabs {
margin-bottom: 24px;
gap: 4px;
justify-content: center;
}
.pct-tab {
padding: 12px 18px;
font-size: 14px;
}
.pct-grid {
gap: 10px;
}
.pct-card__info {
padding: 12px 0;
}
.pct-card__title {
font-size: 14px;
}
}
/* ========== REDUCED MOTION ========== */
@media (prefers-reduced-motion: reduce) {
.pct-tab,
.pct-card,
.pct-card__image img,
.pct-button,
.pct-variant {
transition: none;
}
.pct-grid {
animation: none;
}
}
/* ========== PRINT STYLES ========== */
@media print {
.pct-tabs,
.pct-footer {
display: none;
}
.pct-grid {
display: grid !important;
}
.pct-card {
break-inside: avoid;
}
}
</style>
{% assign selected_collections = block.settings.tab_collections %}
{% assign product_limit = block.settings.products_to_show | default: 10 %}
<div class="pct-section" id="pct-section-{{ block.id }}">
<div class="pct-container">
{% if selected_collections != blank and selected_collections.count > 0 %}
<nav class="pct-tabs" role="tablist" aria-label="Product collection tabs">
{% for selected_collection in selected_collections limit: 3 %}
{% assign tab_id = 'tab-' | append: forloop.index %}
{% assign panel_id = 'panel-' | append: forloop.index %}
<button class="pct-tab{% if forloop.first %} pct-tab--active{% endif %}" id="{{ tab_id }}" data-tab="{{ panel_id }}" data-collection-url="{{ selected_collection.url }}" role="tab" aria-controls="{{ panel_id }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" tabindex="{% if forloop.first %}0{% else %}-1{% endif %}" type="button">
{{ selected_collection.title }}
</button>
{% endfor %}
</nav>
<div class="pct-content">
{% for selected_collection in selected_collections limit: 3 %}
{% assign tab_id = 'tab-' | append: forloop.index %}
{% assign panel_id = 'panel-' | append: forloop.index %}
<div class="pct-grid{% if forloop.first %} pct-grid--active{% endif %}" id="{{ panel_id }}" data-content="{{ panel_id }}" role="tabpanel" aria-labelledby="{{ tab_id }}"{% unless forloop.first %} hidden{% endunless %}>
{% if selected_collection != blank %}
{% for product in selected_collection.products limit: product_limit %}
<div class="pct-card">
{% if block.settings.show_badges %}
{% if product.compare_at_price > product.price %}
<div class="pct-badge">
{% if block.settings.badge_type == 'percentage' %}
Save {{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%
{% elsif block.settings.badge_type == 'amount' %}
Save {{ product.compare_at_price | minus: product.price | money }}
{% else %}
Sale
{% endif %}
</div>
{% elsif product.tags contains 'new' %}
<div class="pct-badge pct-badge--new">New</div>
{% endif %}
{% endif %}
<a href="{{ product.url }}" class="pct-card__image">
{% if product.featured_image %}
<img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
{% else %}
{{ 'product-1' | placeholder_svg_tag: 'pct-placeholder' }}
{% endif %}
</a>
<div class="pct-card__info">
<h3 class="pct-card__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
{% if block.settings.show_ratings and product.metafields.reviews.rating.value != blank %}
<div class="pct-rating">
{% assign rating = product.metafields.reviews.rating.value.rating %}
{% assign rating_count = product.metafields.reviews.rating.value.count %}
<div class="pct-stars" style="--rating: {{ rating }}">
<span class="pct-stars__fill">★★★★★</span>
<span class="pct-stars__empty">★★★★★</span>
</div>
{% if block.settings.show_review_count %}
<span class="pct-rating__count">({{ rating_count }})</span>
{% endif %}
</div>
{% endif %}
<div class="pct-price">
{% if product.compare_at_price > product.price %}
<span class="pct-price__sale">{{ product.price | money }}</span>
<span class="pct-price__compare">{{ product.compare_at_price | money }}</span>
{% else %}
<span class="pct-price__regular">{{ product.price | money }}</span>
{% endif %}
</div>
</div>
</div>
{% endfor %}
{% else %}
<div class="pct-empty"><p>No products found. Please select a collection.</p></div>
{% endif %}
</div>
{% endfor %}
</div>
{% else %}
<div class="pct-content">
<div class="pct-grid pct-grid--active">
<div class="pct-empty"><p>Select up to 3 collections to show this tabber.</p></div>
</div>
</div>
{% endif %}
{% if selected_collections != blank and selected_collections.count > 0 %}
<div class="pct-footer">
<a href="{{ selected_collections.first.url }}" class="pct-button pct-view-all-btn">
<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
<path d="M2 9H16M16 9L9 2M16 9L9 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
View all
</a>
</div>
{% endif %}
</div>
</div>
<script>
(function() {
var section = document.getElementById('pct-section-{{ block.id }}');
if (!section) return;
if (section.dataset.tabberInitialized === 'true') return;
section.dataset.tabberInitialized = 'true';
var tabs = section.querySelectorAll('.pct-tab');
var contents = section.querySelectorAll('.pct-grid');
var viewAllButton = section.querySelector('.pct-view-all-btn');
function setActiveTab(tab) {
var targetId = tab.getAttribute('data-tab');
tabs.forEach(function(t) {
t.classList.remove('pct-tab--active');
t.setAttribute('aria-selected', 'false');
t.setAttribute('tabindex', '-1');
});
contents.forEach(function(c) {
c.classList.remove('pct-grid--active');
c.hidden = true;
});
tab.classList.add('pct-tab--active');
tab.setAttribute('aria-selected', 'true');
tab.setAttribute('tabindex', '0');
var targetContent = section.querySelector('[data-content="' + targetId + '"]');
if (targetContent) {
targetContent.hidden = false;
targetContent.classList.add('pct-grid--active');
}
if (viewAllButton && tab.dataset.collectionUrl) {
viewAllButton.setAttribute('href', tab.dataset.collectionUrl);
}
{% if block.settings.smooth_scroll %}
setTimeout(function() {
var pctContent = section.querySelector('.pct-content');
if (pctContent) {
pctContent.scrollIntoView({
behavior: 'smooth',
block: 'nearest'
});
}
}, 100);
{% endif %}
}
tabs.forEach(function(tab) {
tab.addEventListener('click', function() {
setActiveTab(this);
});
});
if (tabs.length > 0) {
setActiveTab(tabs[0]);
}
})();
</script>
{% schema %}
{
"name": "Product Collection Tabs",
"target": "section",
"class": "section-product-collection-tabs",
"settings": [
{
"type": "range",
"id": "products_to_show",
"min": 2,
"max": 20,
"step": 1,
"label": "Products to show",
"default": 10
},
{
"type": "collection_list",
"id": "tab_collections",
"label": "Tab collections",
"limit": 3,
"info": "Choose up to 3 collections. Each collection becomes one tab."
}
]
}
{% endschema %}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Modal Elements
    const modalSelect = document.querySelector('.vs-search-modal .vs-category-select');
    const modalDisplaySpan = document.querySelector('.vs-search-modal .vs-category-text');
    const modalInput = document.getElementById('vsSearchInput');
    const modal = document.getElementById('vsSearchModal');
    const closeBtn = document.getElementById('vsSearchClose');
    const resultsGrid = document.getElementById('vsPredictiveSearchResults');
    const loadingState = document.getElementById('vsSearchLoading');
    const emptyState = document.getElementById('vsSearchEmpty');
    const viewAllLink = document.querySelector('#vsSearchViewAll a');
    const viewAllDiv = document.getElementById('vsSearchViewAll');
    const defaultState = document.getElementById('vsSearchDefaultState');
    const recentSearchesBlock = document.getElementById('vsRecentSearchesBlock');
    const recentSearchesList = document.getElementById('vsRecentSearchesList');
    const searchForm = document.querySelector('.vs-search-modal .vs-search-wrapper');
    const collectionCache = {};

    // Trigger Elements
    const triggerWrapper = document.getElementById('vsSearchTriggerWrapper');
    const triggerSelect = document.getElementById('vsTriggerSelect');
    const triggerDisplaySpan = document.getElementById('vsTriggerCategoryText');
    const triggerInput = document.getElementById('vsTriggerInput');

    let originalItemsHtml = resultsGrid ? resultsGrid.innerHTML : '';
    let debounceTimer;

    // Local Storage logic
    function loadRecentSearches() {
      let searches = JSON.parse(localStorage.getItem('vsRecentSearches') || '[]');
      if (searches.length > 0) {
        recentSearchesBlock.style.display = 'block';
        recentSearchesList.innerHTML = '';
        searches.forEach((term) => {
          let pill = document.createElement('a');
          pill.className = 'vs-recent-pill';
          pill.textContent = term;
          pill.addEventListener('click', function (e) {
            e.preventDefault();
            if (modalInput) {
              modalInput.value = term;
              if (triggerInput) triggerInput.value = term;
              doPredictiveSearch();
            }
          });
          recentSearchesList.appendChild(pill);
        });
      } else {
        recentSearchesBlock.style.display = 'none';
      }
    }

    function saveRecentSearch(term) {
      if (!term || term.trim() === '') return;
      let searches = JSON.parse(localStorage.getItem('vsRecentSearches') || '[]');
      // Remove if exists
      searches = searches.filter((s) => s.toLowerCase() !== term.toLowerCase());
      // Add to front
      searches.unshift(term);
      // Keep only top 5
      if (searches.length > 5) searches.pop();
      localStorage.setItem('vsRecentSearches', JSON.stringify(searches));
      loadRecentSearches();
    }

    function renderSearchResults(items) {
      resultsGrid.innerHTML = '';
      if (!items || items.length === 0) {
        emptyState.style.display = 'block';
        viewAllDiv.style.display = 'none';
        return;
      }

      items.forEach((item) => {
        const productUrl = item.url || (item.handle ? `/products/${item.handle}` : '#');
        const isProduct = productUrl.indexOf('/products/') === 0 || item.price !== undefined || item.compare_at_price !== undefined;
        const imageSrc = item.image && item.image.src ? item.image.src : item.image;
        const rawPrice = item.price;
        const formattedPrice =
          typeof rawPrice === 'number'
            ? (rawPrice > 999 ? (rawPrice / 100).toFixed(2) : rawPrice.toFixed(2))
            : rawPrice;
        const priceHtml = isProduct && formattedPrice ? `<div class="vs-result-price">${formattedPrice}</div>` : '';

        resultsGrid.insertAdjacentHTML(
          'beforeend',
          `<a href="${productUrl}" class="vs-search-result-item" style="text-decoration: none;">
            <div class="vs-result-image">
              ${
                imageSrc
                  ? `<img src="${imageSrc}" alt="${item.title}" style="width: 100%; height: auto; border-radius: 8px;">`
                  : `<div style="width: 100%; height: 100%; background: #e5e7eb; border-radius: 8px; display:flex; align-items:center; justify-content:center; color:#9ca3af; font-size:12px;">${isProduct ? 'Image' : 'Doc'}</div>`
              }
            </div>
            <div class="vs-result-details">
              <span class="vs-result-vendor">${isProduct ? item.vendor || 'Product' : item.author ? 'Blog' : 'Page'}</span>
              <h4 class="vs-result-title">${item.title}</h4>
              ${priceHtml}
            </div>
          </a>`
        );
      });

      resultsGrid.style.display = 'flex';
      viewAllDiv.style.display = 'block';
    }

    function getCollectionProducts(collectionHandle) {
      if (collectionCache[collectionHandle]) {
        return Promise.resolve(collectionCache[collectionHandle]);
      }

      return fetch(`/collections/${collectionHandle}/products.json?limit=250`)
        .then((response) => response.json())
        .then((data) => {
          const products = data.products || [];
          collectionCache[collectionHandle] = products;
          return products;
        });
    }

    if (searchForm) {
      searchForm.addEventListener('submit', function (e) {
        if (modalInput && modalInput.value) {
          saveRecentSearch(modalInput.value.trim());
        }
      });
    }

    function doPredictiveSearch() {
      if (!modalInput || !resultsGrid) return;

      const q = modalInput.value.trim();
      const collection = modalSelect ? modalSelect.value : '';

      // Update View All link
      if (viewAllLink) {
        let url = collection ? `/collections/${collection}` : '/search?q=' + encodeURIComponent(q);
        viewAllLink.href = url;
      }

      if (q === '') {
        // Restore default 3-column view
        resultsGrid.style.display = 'none';
        defaultState.style.display = 'flex';
        loadingState.style.display = 'none';
        emptyState.style.display = 'none';
        viewAllDiv.style.display = 'none';
        filterProductsFrontEnd(); // Filter the default most searched products
        return;
      }

      // Show loading state, hide default UI
      defaultState.style.display = 'none';
      resultsGrid.style.display = 'none';
      emptyState.style.display = 'none';
      loadingState.style.display = 'block';

      if (collection) {
        getCollectionProducts(collection)
          .then((products) => {
            loadingState.style.display = 'none';
            const normalizedQuery = q.toLowerCase();
            const matchedProducts = products
              .filter((product) => {
                const haystack = [product.title, product.vendor, product.product_type, ...(product.tags || [])]
                  .join(' ')
                  .toLowerCase();
                return haystack.includes(normalizedQuery);
              })
              .slice(0, 6)
              .map((product) => ({
                ...product,
                image: product.image ? product.image.src : '',
                url: `/products/${product.handle}`,
                price: product.price
              }));

            renderSearchResults(matchedProducts);
          })
          .catch((error) => {
            console.error('Collection Search Error:', error);
            loadingState.style.display = 'none';
            emptyState.style.display = 'block';
            viewAllDiv.style.display = 'none';
          });
        return;
      }

      let url = `/search/suggest.json?q=${encodeURIComponent(
        q
      )}&resources[type]=product,page,article&resources[limit]=6`;

      fetch(url)
        .then((response) => response.json())
        .then((data) => {
          loadingState.style.display = 'none';
          let products = data.resources.results.products || [];
          let pages = data.resources.results.pages || [];
          let articles = data.resources.results.articles || [];

          // Merge results (favoring products)
          let combined = [...products, ...pages, ...articles].slice(0, 6);

          renderSearchResults(combined);
        })
        .catch((error) => {
          console.error('Predictive Search Error:', error);
          loadingState.style.display = 'none';
          resultsGrid.style.display = 'flex';
        });
    }

    function handleInput() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(doPredictiveSearch, 300); // 300ms debounce
    }

    function filterProductsFrontEnd() {
      if (modalInput && modalInput.value.trim() !== '') return;

      if (!modalSelect) return;
      const selectedText = modalSelect.options[modalSelect.selectedIndex]
        ? modalSelect.options[modalSelect.selectedIndex].text
        : 'All categories';
      const selectedValue = modalSelect.value;
      const defaultItems = document.querySelectorAll('.vs-default-products-grid .vs-search-result-item');

      defaultItems.forEach((item) => {
        const itemCat = item.getAttribute('data-category');
        if (itemCat === null) return;

        if (!selectedValue || selectedValue === '' || selectedText === 'All categories') {
          item.style.display = 'flex';
        } else if (itemCat.includes(selectedText) || itemCat.includes(selectedValue)) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });
    }

    function openModal() {
      if (modal) {
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';

        // Load local storage searches
        loadRecentSearches();

        // Sync value from trigger to modal
        if (triggerInput && modalInput) {
          modalInput.value = triggerInput.value;
          modalInput.focus();
        }
        if (triggerSelect && modalSelect && triggerDisplaySpan && modalDisplaySpan) {
          modalSelect.value = triggerSelect.value;
          modalDisplaySpan.textContent = triggerDisplaySpan.textContent;
        }

        if (modalInput && modalInput.value.trim() !== '') {
          doPredictiveSearch();
        } else {
          resultsGrid.style.display = 'none';
          defaultState.style.display = 'flex';
          viewAllDiv.style.display = 'none';
          filterProductsFrontEnd();
        }
      }
    }

    // Trigger Select Change
    if (triggerSelect && triggerDisplaySpan) {
      triggerSelect.addEventListener('change', function () {
        if (triggerSelect.options[triggerSelect.selectedIndex]) {
          const text = triggerSelect.options[triggerSelect.selectedIndex].text;
          triggerDisplaySpan.textContent = text;

          if (modalSelect && modalDisplaySpan) {
            modalSelect.value = triggerSelect.value;
            modalDisplaySpan.textContent = text;
          }

          if (modalInput && modalInput.value.trim() !== '') {
            doPredictiveSearch();
          } else {
            filterProductsFrontEnd();
          }
        }
      });
    }

    // Modal Select Change
    if (modalSelect && modalDisplaySpan) {
      modalSelect.addEventListener('change', function () {
        if (modalSelect.options[modalSelect.selectedIndex]) {
          const text = modalSelect.options[modalSelect.selectedIndex].text;
          modalDisplaySpan.textContent = text;

          if (triggerSelect && triggerDisplaySpan) {
            triggerSelect.value = modalSelect.value;
            triggerDisplaySpan.textContent = text;
          }

          if (modalInput && modalInput.value.trim() !== '') {
            doPredictiveSearch();
          } else {
            filterProductsFrontEnd();
          }
        }
      });
    }

    // Open Modal when focusing/clicking on trigger input
    if (triggerInput) {
      triggerInput.addEventListener('focus', openModal);
      triggerInput.addEventListener('click', openModal);
      // Sync typing immediately
      triggerInput.addEventListener('input', function () {
        if (modalInput) {
          modalInput.value = triggerInput.value;
          doPredictiveSearch();
        }
      });
    }

    // Modal input syncing and searching
    if (modalInput) {
      modalInput.addEventListener('input', function () {
        if (triggerInput) triggerInput.value = modalInput.value;
        handleInput();
      });

      // Save search on enter
      modalInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
          saveRecentSearch(modalInput.value.trim());
        }
      });
    }

    // Modal close
    if (closeBtn && modal) {
      closeBtn.addEventListener('click', function (e) {
        e.preventDefault();
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      });
    }

    // Close on overlay click
    const overlay = document.querySelector('.vs-search-modal-overlay');
    if (overlay && modal) {
      overlay.addEventListener('click', function () {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      });
    }

    // Handle Escape key
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && modal && modal.classList.contains('is-open')) {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      }
    });

    // Initial filter state
    filterProductsFrontEnd();
  });
</script>



<div id="vs-search-section-{{ block.id }}" class="page-width vs-search-section" style="border-bottom:1px solid #eee">
  <!-- Trigger for the modal (can be placed wherever the icon is needed) -->
  <div class="vs-search-trigger-container">
    <!-- New Trigger that looks like the Search Bar -->
    <div class="vs-search-wrapper" id="vsSearchTriggerWrapper">
      <!-- Left: Category Dropdown (Trigger) -->
      <div class="vs-search-category">
        <select class="vs-category-select" id="vsTriggerSelect">
          <option value="">All categories</option>
          {% for collection in collections %}
            <option value="{{ collection.handle }}">{{ collection.title }}</option>
          {% endfor %}
        </select>
        <div class="vs-category-display">
          <span class="vs-category-text" id="vsTriggerCategoryText">All categories</span>
          <svg
            class="vs-icon-chevron"
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
      </div>

      <!-- Middle: Search Input (Trigger) -->
      <div class="vs-search-input-wrapper">
        <input
          type="text"
          placeholder="What are you searching for?"
          class="vs-search-input"
          id="vsTriggerInput"
          autocomplete="off"
        >
      </div>

      <!-- Right: Search Icon -->
      <div class="vs-search-button" style="pointer-events: none;">
        <svg
          class="vs-icon-search"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </div>
    </div>
  </div>
</div>

<!-- Full Screen Search Modal -->
<div class="vs-search-modal" id="vsSearchModal">
  <div class="vs-search-modal-overlay"></div>
  <div class="vs-search-modal-content">
    <div class="vs-search-modal-header page-width">
      <!-- Close Button at top right -->
      <button class="vs-search-close" id="vsSearchClose" aria-label="Close Search">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <!-- The Search Bar -->
      <form action="/search" method="get" class="vs-search-wrapper">
        <!-- Left: Category Dropdown -->
        <div class="vs-search-category">
          <select name="category" class="vs-category-select">
            <option value="">All categories</option>
            {% for collection in collections %}
              <option value="{{ collection.handle }}">{{ collection.title }}</option>
            {% endfor %}
          </select>
          <div class="vs-category-display">
            <span class="vs-category-text">All categories</span>
            <svg
              class="vs-icon-chevron"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>

        <!-- Middle: Search Input -->
        <div class="vs-search-input-wrapper">
          <input
            type="text"
            name="q"
            placeholder="What are you searching for?"
            class="vs-search-input"
            id="vsSearchInput"
            autocomplete="off"
          >
        </div>

        <!-- Right: Search Button -->
        <button type="submit" class="vs-search-button">
          <svg
            class="vs-icon-search"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>
    </div>

    <!-- Search Results Area -->
    <div class="vs-search-results-area page-width">
      <!-- Default Empty State (3 Columns) -->
      <div class="vs-search-default-state" id="vsSearchDefaultState">
        <!-- Column 1: Need Help -->
        <div class="vs-default-col">
          <h3 class="vs-col-title">Need Help?</h3>
          <div class="vs-help-links">
            <a href="/" class="vs-help-link">Home</a>
            <a href="/collections/all" class="vs-help-link">Catalog</a>
            <a href="/pages/contact" class="vs-help-link">Contact</a>
          </div>
        </div>

        <!-- Column 2: Recent Searches & Products -->
        <div class="vs-default-col flex-2">
          <div id="vsRecentSearchesBlock" style="display: none; margin-bottom: 30px;">
            <h3 class="vs-col-title">Recent searches</h3>
            <div class="vs-recent-searches-list" id="vsRecentSearchesList">
              <!-- Injected by JS -->
            </div>
          </div>

          <h3 class="vs-col-title">Most searched products</h3>
          <div class="vs-search-results-grid vs-default-products-grid">
            {% assign has_products = false %}
            {% for product in collections.all.products limit: 3 %}
              {% assign has_products = true %}
              {% assign product_collections = '' %}
              {% for c in product.collections %}
                {% assign product_collections = product_collections
                  | append: c.title
                  | append: ','
                  | append: c.handle
                  | append: ','
                %}
              {% endfor %}
              <a
                href="{{ product.url }}"
                class="vs-search-result-item"
                data-category="{{ product_collections }}"
                style="text-decoration: none;"
              >
                <div class="vs-result-image">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | img_url: '200x' }}"
                      alt="{{ product.title | escape }}"
                      style="width: 100%; height: auto; border-radius: 8px;"
                    >
                  {% else %}
                    <div style="width: 100%; padding-bottom: 100%; background: #e5e7eb; border-radius: 8px;"></div>
                  {% endif %}
                </div>
                <div class="vs-result-details">
                  <span class="vs-result-vendor">{{ product.vendor }}</span>
                  <h4 class="vs-result-title">{{ product.title }}</h4>
                  <div class="vs-result-price">{{ product.price | money }}</div>
                </div>
              </a>
            {% endfor %}

            {% if has_products == false %}
              <!-- Fallbacks -->
              <a
                href="#"
                class="vs-search-result-item"
                data-category="Home page,frontpage"
                style="text-decoration: none;"
              >
                <div class="vs-result-image">
                  <div style="width: 100%; padding-bottom: 100%; background: #e5e7eb; border-radius: 50%;"></div>
                </div>
                <div class="vs-result-details">
                  <span class="vs-result-vendor">Decor</span>
                  <h4 class="vs-result-title">Cream Modern Wooden Frame Sofa</h4>
                  <div class="vs-result-price">$750.00</div>
                </div>
              </a>
              <a href="#" class="vs-search-result-item" data-category="Decor,decor" style="text-decoration: none;">
                <div class="vs-result-image">
                  <div style="width: 100%; padding-bottom: 150%; background: #e5e7eb; border-radius: 8px;"></div>
                </div>
                <div class="vs-result-details">
                  <span class="vs-result-vendor">Lighting</span>
                  <h4 class="vs-result-title">Industrial Adjustable Desk Lamp</h4>
                  <div class="vs-result-price">$29.00</div>
                </div>
              </a>
              <a
                href="#"
                class="vs-search-result-item"
                data-category="Home page,frontpage,Decor,decor"
                style="text-decoration: none;"
              >
                <div class="vs-result-image">
                  <div style="width: 100%; padding-bottom: 100%; background: #e5e7eb; border-radius: 50%;"></div>
                </div>
                <div class="vs-result-details">
                  <span class="vs-result-vendor">Decor</span>
                  <h4 class="vs-result-title">Modern Bean Bag</h4>
                  <div class="vs-result-price">$79.00</div>
                </div>
              </a>
            {% endif %}
          </div>
        </div>

        <!-- Column 3: Collections -->
        <div class="vs-default-col">
          <h3 class="vs-col-title">Explore our collections</h3>
          <div class="vs-explore-collections">
            <!-- Try to loop real collections, else fallback -->
            {% assign collection_count = 0 %}
            {% for col in collections limit: 4 %}
              {% if col.handle != 'all' and col.handle != 'frontpage' %}
                {% assign collection_count = collection_count | plus: 1 %}
                <a href="{{ col.url }}" class="vs-collection-card">
                  <div class="vs-collection-img">
                    {% if col.image %}
                      <img src="{{ col.image | img_url: '100x' }}" alt="{{ col.title | escape }}">
                    {% else %}
                      <div style="width:100%; height:100%; background:#e5e7eb;"></div>
                    {% endif %}
                  </div>
                  <span class="vs-collection-title">{{ col.title }}</span>
                </a>
              {% endif %}
            {% endfor %}

            {% if collection_count == 0 %}
              <a href="#" class="vs-collection-card">
                <div class="vs-collection-img">
                  <div style="width:100%; height:100%; background:#e5e7eb; border-radius:8px;"></div>
                </div>
                <span class="vs-collection-title">Chairs Furniture</span>
              </a>
              <a href="#" class="vs-collection-card">
                <div class="vs-collection-img">
                  <div style="width:100%; height:100%; background:#e5e7eb; border-radius:8px;"></div>
                </div>
                <span class="vs-collection-title">Sofas</span>
              </a>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- Active Search Results Grid (Hidden by default) -->
      <div class="vs-search-results-grid" id="vsPredictiveSearchResults" style="display: none;"></div>

      <!-- Predictive Search Loading State (hidden by default) -->
      <div class="vs-search-loading" id="vsSearchLoading" style="display: none; text-align: center; padding: 40px 0;">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          class="vs-spinner"
          style="animation: spin 1s linear infinite;"
        >
          <circle cx="12" cy="12" r="10" stroke="#e5e7eb" stroke-width="4"></circle>
          <path d="M12 2a10 10 0 0 1 10 10" stroke="#111827" stroke-width="4" stroke-linecap="round"></path>
        </svg>
      </div>

      <!-- Predictive Search Empty State (hidden by default) -->
      <div
        class="vs-search-empty"
        id="vsSearchEmpty"
        style="display: none; text-align: center; padding: 40px 0; color: #6b7280;"
      >
        No results found. Try a different search term.
      </div>

      <div class="vs-search-view-all" id="vsSearchViewAll">
        <a href="/search?q=">View all &raquo;</a>
      </div>
    </div>
  </div>
</div>


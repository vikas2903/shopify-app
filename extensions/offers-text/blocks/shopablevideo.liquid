{% liquid
  assign item_count = 0
  assign product_handles = block.settings.product_handles | default: ''
  assign product_handles_array = product_handles | split: ','
  for i in (1..5)
    assign video_key = 'video_' | append: i
    assign video_url_key = 'video_url_' | append: i
    assign product_index = i | minus: 1
    assign product_handle = product_handles_array[product_index] | strip
    assign product_item = all_products[product_handle]
    if block.settings[video_key] != blank or block.settings[video_url_key] != blank or product_item != blank
      assign item_count = item_count | plus: 1
    endif
  endfor
%}

<section class="ugc-reels ugc-reels-{{ block.id }}">
  <div class="ugc-reels__inner page-width">
    {% if block.settings.heading != blank %}
      <h2 class="ugc-reels__heading">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ugc-reels__track">
      {% for i in (1..5) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign video_url_key = 'video_url_' | append: i
          assign view_count_key = 'view_count_' | append: i

          assign product_index = i | minus: 1
          assign product_handle = product_handles_array[product_index] | strip
          assign product_item = all_products[product_handle]
          assign featured_image = product_item.featured_image
          assign video_file = block.settings[video_key]
          assign video_url = block.settings[video_url_key]
          assign view_count = block.settings[view_count_key]
        %}
        {% if video_file != blank or video_url != blank or product_item != blank or featured_image != blank %}
          <article class="ugc-card" data-ugc-card>
            <div class="ugc-card__media">
              {% if video_file != blank %}
                {{ video_file | video_tag:
                  image_size: '1100x',
                  autoplay: false,
                  loop: true,
                  controls: false,
                  muted: true,
                  playsinline: true,
                  class: 'ugc-card__video'
                }}
              {% elsif video_url != blank %}
                <video class="ugc-card__video" playsinline loop preload="metadata" muted>
                  <source src="{{ video_url }}" type="video/mp4">
                </video>
              {% elsif featured_image %}
                <img
                  class="ugc-card__fallback"
                  src="{{ featured_image | image_url: width: 1100 }}"
                  alt="{{ featured_image.alt | escape }}"
                  loading="lazy"
                >
              {% else %}
                <div class="ugc-card__placeholder" aria-hidden="true"></div>
              {% endif %}

              {% if view_count != blank %}
                <span class="ugc-card__views">{{ view_count }}</span>
              {% endif %}

              <button class="ugc-card__play" type="button" aria-label="Play or pause">
                <svg viewBox="0 0 100 100" width="44" height="44" aria-hidden="true">
                  <circle cx="50" cy="50" r="48" stroke-width="4" fill="rgba(0,0,0,.45)"></circle>
                  <polygon class="icon--play" points="40,30 75,50 40,70" fill="#fff"></polygon>
                  <g class="icon--pause" style="display:none">
                    <rect x="38" y="32" width="10" height="36" fill="#fff"></rect>
                    <rect x="56" y="32" width="10" height="36" fill="#fff"></rect>
                  </g>
                </svg>
              </button>
            </div>

            <a href="{% if product_item %}{{ product_item.url }}{% else %}#{% endif %}" class="ugc-card__meta">
              <div class="ugc-card__info">
                <div class="ugc-card__title">
                  {% if product_item %}
                    {{ product_item.title }}
                  {% else %}
                    Product title
                  {% endif %}
                </div>

                <div class="ugc-card__price">
                  {% if product_item %}
                    {% if product_item.compare_at_price_max > product_item.price_max %}
                      <span class="ugc-card__compare">{{ product_item.compare_at_price_max | money }}</span>
                    {% endif %}
                    <span class="ugc-card__current">{{ product_item.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ugc-reels-{{ block.id }} .ugc-reels__heading { text-align: center; letter-spacing: .02em; text-transform: uppercase; font-size: 42px; margin: 40px 0 30px; }
  .ugc-reels-{{ block.id }} .ugc-reels__track { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 16px; }
  .ugc-reels-{{ block.id }} .ugc-card { border-radius: {{ block.settings.border_radius }}px; overflow: hidden; background: #fff; box-shadow: 0 6px 22px rgba(0,0,0,.06); display: flex; flex-direction: column; position: relative; }
  .ugc-reels-{{ block.id }} .ugc-card__media { position: relative; aspect-ratio: 3 / 5; overflow: hidden; }
  .ugc-reels-{{ block.id }} .ugc-card__video,
  .ugc-reels-{{ block.id }} .ugc-card__fallback,
  .ugc-reels-{{ block.id }} .ugc-card__placeholder { width: 100%; height: 100%; object-fit: cover; display: block; background: #f3f3f3; }
  .ugc-reels-{{ block.id }} .ugc-card__play { position: absolute; inset: 0; display: grid; place-items: center; border: 0; background: none; cursor: pointer; }
  .ugc-reels-{{ block.id }} .ugc-card__views { position: absolute; top: 10px; right: 10px; z-index: 2; padding: 6px 10px; border-radius: 999px; background: rgba(0,0,0,.55); color: #fff; font-size: 11px; font-weight: 600; line-height: 1; }
  .ugc-reels-{{ block.id }} .ugc-card__meta { text-decoration: none; color: inherit; display: block; padding: 10px 12px; position: absolute; backdrop-filter: blur(8px); background: #fff; left: 5px; right: 5px; bottom: 5px; border-radius: 8px; }
  .ugc-reels-{{ block.id }} .ugc-card__title { font-size: 14px; line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .ugc-reels-{{ block.id }} .ugc-card__price { margin-top: 6px; font-size: 14px; }
  .ugc-reels-{{ block.id }} .ugc-card__compare { text-decoration: line-through; opacity: .6; margin-right: 6px; }
  .ugc-reels-{{ block.id }} .ugc-card__current { font-weight: 700; color: #ce1178; }
  @media (max-width: 1024px) { .ugc-reels-{{ block.id }} .ugc-reels__track { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 768px) { .ugc-reels-{{ block.id }} .ugc-reels__track { grid-template-columns: repeat(2, minmax(0, 1fr)); padding:0 10px; } }
  @media (max-width: 749px) {
    .ugc-reels-{{ block.id }} .ugc-reels__heading { font-size: 28px; }
    .ugc-reels-{{ block.id }} .ugc-card__title, .ugc-reels-{{ block.id }} .ugc-card__price { font-size: 10px; }
  }
</style>

<script>
  (function() {
    const root = document.querySelector('.ugc-reels-{{ block.id }}');
    if (!root) return;

    const cards = root.querySelectorAll('[data-ugc-card]');

    cards.forEach((card) => {
      const video = card.querySelector('.ugc-card__video');
      const btn = card.querySelector('.ugc-card__play');
      if (!video || !btn) return;

      const iconPlay = btn.querySelector('.icon--play');
      const iconPause = btn.querySelector('.icon--pause');

      function setState(playing) {
        iconPlay.style.display = playing ? 'none' : 'block';
        iconPause.style.display = playing ? 'block' : 'none';
      }

      btn.addEventListener('click', function() {
        if (video.paused) {
          cards.forEach((otherCard) => {
            const otherVideo = otherCard.querySelector('.ugc-card__video');
            if (otherVideo && otherVideo !== video) {
              otherVideo.pause();
            }
          });
          video.muted = true;
          video.play().catch(function() {});
          setState(true);
        } else {
          video.pause();
          setState(false);
        }
      });

      video.addEventListener('pause', function() { setState(false); });
      video.addEventListener('play', function() { setState(true); });
    });
  })();
</script>
  
{% schema %}
{
  "name": "Shopable video",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SEE PEOPLE GO GAGA OVER OUR TRADITIONALS" },
    { "type": "range", "id": "border_radius", "min": 0, "max": 36, "step": 1, "label": "Card border radius", "default": 18 },
    { "type": "textarea", "id": "product_handles", "label": "Product handles", "info": "Enter up to 5 product handles separated by commas. Order matches Video 1, Video 2, Video 3, Video 4, Video 5. Example: red-dress, blue-shirt, summer-kurta" },

    { "type": "header", "content": "Video 1" },
    { "type": "video", "id": "video_1", "label": "Shopify video" },
    { "type": "url", "id": "video_url_1", "label": "MP4 video URL" },
    { "type": "text", "id": "view_count_1", "label": "View count", "default": "3.8K" },

    { "type": "header", "content": "Video 2" },
    { "type": "video", "id": "video_2", "label": "Shopify video" },
    { "type": "url", "id": "video_url_2", "label": "MP4 video URL" },
    { "type": "text", "id": "view_count_2", "label": "View count", "default": "3.8K" },

    { "type": "header", "content": "Video 3" },
    { "type": "video", "id": "video_3", "label": "Shopify video" },
    { "type": "url", "id": "video_url_3", "label": "MP4 video URL" },
    { "type": "text", "id": "view_count_3", "label": "View count", "default": "3.8K" },

    { "type": "header", "content": "Video 4" },
    { "type": "video", "id": "video_4", "label": "Shopify video" },
    { "type": "url", "id": "video_url_4", "label": "MP4 video URL" },
    { "type": "text", "id": "view_count_4", "label": "View count", "default": "3.8K" },

    { "type": "header", "content": "Video 5" },
    { "type": "video", "id": "video_5", "label": "Shopify video" },
    { "type": "url", "id": "video_url_5", "label": "MP4 video URL" },
    { "type": "text", "id": "view_count_5", "label": "View count", "default": "3.8K" }
  ]
}
{% endschema %}
 
